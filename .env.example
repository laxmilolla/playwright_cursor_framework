# Copy to .env and fill in. Used for Login.gov, TOTP, and hub URL.

# Hub base URL (required; no default). Use stage or prod per environment.
# BASE_URL=https://hub-stage.datacommons.cancer.gov

LOGIN_EMAIL=your@email.com
LOGIN_PASSWORD=your_password

# TOTP: use one of the following.
# Option A – single key for all users
# TOTP_SECRET_KEY=your_base32_secret_here

# Option B – user-specific key (email with @ and . → _ in var name, e.g. automationlaxmi@yahoo.com → AUTOMATIONLAXMI_YAHOO_COM)
# TOTP_USER_EMAIL=automationlaxmi@yahoo.com
# TOTP_SECRET_KEY_TS_AUTOMATIONLAXMI_YAHOO_COM=your_base32_secret
